# ── Stage 4: runtime ──────────────────────────────────────────────────────────
FROM debian AS runtime

WORKDIR /app

COPY ./target/debug/anvil-notify /usr/bin/
COPY ./target/debug/outbox-worker /usr/bin/
COPY ./target/debug/anctl /usr/bin/
COPY ./migrations  ./migrations
COPY ./config      ./config

EXPOSE 8080

ENTRYPOINT ["anvil-notify"]
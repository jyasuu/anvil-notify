  "query": "\n            INSERT INTO block_list (kind, value, reason, active)\n            VALUES ($1, $2, $3, TRUE)\n            ON CONFLICT (kind, lower(value))\n            DO UPDATE SET active = TRUE, reason = EXCLUDED.reason, updated_at = now()\n            RETURNING id, kind, value, reason, active, created_at\n            ",
